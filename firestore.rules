rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Each authenticated user can only read/write their own profile document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Per-user activity logs used by the dashboard.
    match /users/{userId}/activityLogs/{logId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Per-user feeding history (Feed Now button timestamps).
    match /users/{userId}/feedingLogs/{logId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Deny all other document access by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
